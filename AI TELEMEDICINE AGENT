def big_divider():
    print("=" * 55)

def check_emergency(text):
    t = text.lower()
    return [e for e in EMERGENCY_SYMPTOMS if e in t]

def diagnose(symptoms_text):
    """Enhanced symptom matching using string processing and normalized scoring."""
    # Clean input text: lowercase and remove basic punctuation symbols
    clean_text = re.sub(r'[^\w\s]', ' ', symptoms_text.lower())
    words = clean_text.split()

    scores = {}
    for disease, info in DISEASES.items():
        match_count = 0
        for kw in info["keywords"]:
            # Check if multi-word keywords match exactly in text (e.g., 'body pain')
            if " " in kw and kw in clean_text:
                match_count += 2  # Give higher weights to explicit multi-word matches
            # Check if singular keyword blocks exist inside the tokenized word array
            elif kw in words:
                match_count += 1

        if match_count > 0:
            scores[disease] = match_count

    if not scores:
        return None, 0

    # Pick the disease with the maximum matching weight
    best = max(scores, key=scores.get)
    total_kw = len(DISEASES[best]["keywords"])

    # Calculate an intuitive confidence percentage
    confidence = min(95, int((scores[best] / (total_kw * 0.5)) * 100))
    if confidence < 15:
        confidence = 25 # Minimum confidence floor baseline

    return best, confidence

def get_priority(risk_score):
    if risk_score >= 75:
        return "EMERGENCY - Visit hospital immediately"
    elif risk_score >= 50:
        return "Book appointment within 24 hours"
    else:
        return "Routine consultation"

def get_risk_label(risk_score):
    if risk_score <= 40:
        return "Low"
    elif risk_score <= 70:
        return "Moderate"
    else:
        return "High"

def load_history():
    if os.path.exists(HISTORY_FILE):
        with open(HISTORY_FILE) as f:
            return json.load(f)
    return []

def save_to_history(record):
    history = load_history()
    history.append(record)
    with open(HISTORY_FILE, "w") as f:
        json.dump(history, f, indent=2)

